                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label styleClass="movie-genre-pill" text="Ciencia Ficcion" />
                                    <Label styleClass="movie-meta" text="155 min" />
                                </HBox>
                                <Label styleClass="movie-description" text="La saga de Arrakis continua." wrapText="true" />
                            </VBox>

                            <VBox spacing="12" styleClass="movie-card">
                                <HBox alignment="TOP_LEFT" spacing="10">
                                    <Label styleClass="movie-title" text="El Ultimo Detective" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button fx:id="btnEliminarPeliculaDemo2" styleClass="icon-button" text="X" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label styleClass="movie-genre-pill" text="Thriller" />
                                    <Label styleClass="movie-meta" text="118 min" />
                                </HBox>
                                <Label styleClass="movie-description" text="Un caso imposible en la ciudad." wrapText="true" />
                            </VBox>

                            <VBox spacing="12" styleClass="movie-card">
                                <HBox alignment="TOP_LEFT" spacing="10">
                                    <Label styleClass="movie-title" text="Corazones de Papel" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button fx:id="btnEliminarPeliculaDemo3" styleClass="icon-button" text="X" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label styleClass="movie-genre-pill" text="Drama" />
                                    <Label styleClass="movie-meta" text="102 min" />
                                </HBox>
                                <Label styleClass="movie-description" text="Amor y memoria." wrapText="true" />
                            </VBox>
                        </FlowPane>
                    </HBox>
                </VBox>

                <VBox fx:id="salasView" managed="false" spacing="24" styleClass="main-content" visible="false">
