                        <Label styleClass="page-subtitle" text="Cartelera del cine" />
                    </VBox>

                    <HBox alignment="TOP_LEFT" spacing="24" styleClass="peliculas-layout">
                        <VBox fx:id="peliculaForm" maxWidth="320" minWidth="300" spacing="16" styleClass="form-card" HBox.hgrow="NEVER">
                            <Label styleClass="panel-title" text="Nueva pelicula" />

                            <VBox spacing="8">
                                <Label styleClass="form-label" text="Titulo" />
                                <TextField fx:id="txtPeliculaTitulo" promptText="Nombre de la pelicula" styleClass="form-input" />
                            </VBox>

                            <VBox spacing="8">
                                <Label styleClass="form-label" text="Genero" />
                                <TextField fx:id="txtPeliculaGenero" promptText="Accion, drama, comedia..." styleClass="form-input" />
                            </VBox>

                            <VBox spacing="8">
                                <Label styleClass="form-label" text="Duracion (min)" />
                                <TextField fx:id="txtPeliculaDuracion" promptText="120" styleClass="form-input" />
                            </VBox>

                            <VBox spacing="8">
                                <Label styleClass="form-label" text="Sinopsis" />
                                <TextArea fx:id="txtPeliculaSinopsis" prefRowCount="4" promptText="Resumen breve para la cartelera" styleClass="form-textarea" wrapText="true" />
                            </VBox>

                            <Button fx:id="btnAgregarPelicula" maxWidth="Infinity" styleClass="primary-button" text="+  Agregar" />
                        </VBox>

