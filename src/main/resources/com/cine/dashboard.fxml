                            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="panel-header">
                                <Label styleClass="panel-icon" text="\$" />
                                <Label styleClass="panel-title" text="Ultimas ventas" />
                            </HBox>
                            <VBox fx:id="ventasListContainer" spacing="16" styleClass="list-container">
                                <HBox alignment="CENTER_LEFT" styleClass="venta-row">
                                    <VBox spacing="2">
                                        <Label styleClass="row-title" text="Venta #001" />
                                        <Label styleClass="row-subtitle" text="Cliente registrado - Sala 2" />
                                    </VBox>
                                    <Region HBox.hgrow="ALWAYS" />
                                    <VBox alignment="CENTER_RIGHT" spacing="2">
                                        <Label styleClass="row-amount" text="Bs 45.00" />
                                        <Label styleClass="status-pill, status-activa" text="ACTIVA" />
                                    </VBox>
                                </HBox>
                            </VBox>
                        </VBox>

                        <VBox fx:id="panelFunciones" prefWidth="380" spacing="18" styleClass="panel-card" HBox.hgrow="NEVER">
                            <Label styleClass="panel-title" text="Proximas funciones" />
