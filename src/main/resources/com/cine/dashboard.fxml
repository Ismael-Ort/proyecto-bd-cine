                                    <Label styleClass="funcion-title" text="Dune: Parte Tres" />
                                    <Label styleClass="funcion-subtitle" text="Sala 1 - 20:00" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label styleClass="funcion-title" text="El Ultimo Detective" />
                                    <Label styleClass="funcion-subtitle" text="Sala 2 - 21:30" />
                                </VBox>
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox fx:id="peliculasView" managed="false" spacing="24" styleClass="main-content" visible="false">
